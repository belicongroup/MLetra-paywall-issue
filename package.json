{
  "name": "m-letras-payment-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:android": "npm run build && npx cap sync android && node scripts/fix-capacitor-compat.cjs",
    "cap:add:android": "npx cap add android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:ios": "npx cap open ios",
    "postinstall": "node scripts/fix-capacitor-compat.cjs"
  },
  "dependencies": {
    "@adplorg/capacitor-in-app-purchase": "^2.0.64",
    "@capacitor/android": "7.0.0",
    "@capacitor/cli": "7.0.0",
    "@capacitor/core": "7.0.0",
    "@capacitor/ios": "7.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
